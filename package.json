{
  "name": "git-file-explorer",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.1.2",
  "publisher": "ethanheo",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/ethan-heo/git-file-explorer-extension.git"
  },
  "bugs": {
    "url": "https://github.com/ethan-heo/git-file-explorer-extension/issues"
  },
  "homepage": "https://github.com/ethan-heo/git-file-explorer-extension#readme",
  "packageManager": "pnpm@10.19.0",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/git-file-explorer.png",
  "keywords": [
    "git",
    "history",
    "diff",
    "file"
  ],
  "activationEvents": [
    "onView:gitFileExplorer.commitHistory",
    "onView:gitFileExplorer.commitFiles",
    "onCommand:gitFileExplorer.showHistory",
    "onCommand:gitFileExplorer.filterByDate",
    "onCommand:gitFileExplorer.filterByAuthor",
    "onCommand:gitFileExplorer.togglePin",
    "onCommand:gitFileExplorer.showFileHistoryFromCommitFile",
    "onCommand:gitFileExplorer.diffWithPrevious",
    "onCommand:gitFileExplorer.diffWithNext"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitFileExplorer",
          "title": "%viewsContainers.gitFileExplorer.title%",
          "icon": "resources/git-file-explorer.svg"
        }
      ]
    },
    "views": {
      "gitFileExplorer": [
        {
          "id": "gitFileExplorer.commitHistory",
          "name": "%views.gitFileExplorer.commitHistory.name%"
        },
        {
          "id": "gitFileExplorer.commitFiles",
          "name": "%views.gitFileExplorer.commitFiles.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "gitFileExplorer.showHistory",
        "title": "%commands.gitFileExplorer.showHistory.title%",
        "icon": "$(history)"
      },
      {
        "command": "gitFileExplorer.filterByDate",
        "title": "%commands.gitFileExplorer.filterByDate.title%",
        "icon": "$(calendar)"
      },
      {
        "command": "gitFileExplorer.filterByAuthor",
        "title": "%commands.gitFileExplorer.filterByAuthor.title%",
        "icon": "$(account)"
      },
      {
        "command": "gitFileExplorer.togglePin",
        "title": "%commands.gitFileExplorer.togglePin.title%",
        "icon": "$(pin)"
      },
      {
        "command": "gitFileExplorer.openFileAtCommit",
        "title": "%commands.gitFileExplorer.openFileAtCommit.title%"
      },
      {
        "command": "gitFileExplorer.showFileHistoryFromCommitFile",
        "title": "%commands.gitFileExplorer.showFileHistoryFromCommitFile.title%",
        "icon": "$(history)"
      },
      {
        "command": "gitFileExplorer.diffWithPrevious",
        "title": "%commands.gitFileExplorer.diffWithPrevious.title%",
        "icon": "$(arrow-up)"
      },
      {
        "command": "gitFileExplorer.diffWithNext",
        "title": "%commands.gitFileExplorer.diffWithNext.title%",
        "icon": "$(arrow-down)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "gitFileExplorer.showHistory",
          "when": "!explorerResourceIsFolder",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "gitFileExplorer.togglePin",
          "when": "view == gitFileExplorer.commitHistory",
          "group": "navigation@1"
        },
        {
          "command": "gitFileExplorer.filterByDate",
          "when": "view == gitFileExplorer.commitHistory",
          "group": "navigation@2"
        },
        {
          "command": "gitFileExplorer.filterByAuthor",
          "when": "view == gitFileExplorer.commitHistory",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "gitFileExplorer.showFileHistoryFromCommitFile",
          "when": "view == gitFileExplorer.commitFiles && viewItem == file",
          "group": "inline@1"
        },
        {
          "command": "gitFileExplorer.diffWithPrevious",
          "when": "view == gitFileExplorer.commitFiles && viewItem == file",
          "group": "inline@2"
        },
        {
          "command": "gitFileExplorer.diffWithNext",
          "when": "view == gitFileExplorer.commitFiles && viewItem == file",
          "group": "inline@3"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "gitFileExplorer.commitHistory",
        "contents": "%viewsWelcome.gitFileExplorer.commitHistory%"
      },
      {
        "view": "gitFileExplorer.commitFiles",
        "contents": "%viewsWelcome.gitFileExplorer.commitFiles%"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "check": "pnpm run compile",
    "changelog": "node scripts/update-changelog.mjs",
    "release:tag": "node scripts/create-release-tag.mjs",
    "package:vsix": "pnpm run changelog && pnpm run check && pnpm dlx @vscode/vsce package",
    "vscode:prepublish": "pnpm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  }
}
